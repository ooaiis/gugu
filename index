<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>구구단 급수제 관리 시스템 & 시뮬레이터</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts (Noto Sans KR) -->
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  <!-- html2canvas 라이브러리 추가 (이미지 저장용) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <!-- Firebase SDK Compat v10 (실시간 랭킹 공유용) -->
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>
  <style>
    body {
      font-family: 'Noto Sans KR', sans-serif;
    }
    .custom-shadow {
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
    }
    /* 키패드 터치 효과 */
    .key-btn:active {
      transform: scale(0.95);
    }
    /* 🚀 3, 2, 1, 시작! 카운트다운 애니메이션 */
    @keyframes pop-in {
      0% {
        transform: scale(0.3);
        opacity: 0;
      }
      35% {
        transform: scale(1.3);
        opacity: 1;
      }
      75% {
        transform: scale(1);
        opacity: 1;
      }
      100% {
        transform: scale(0.7);
        opacity: 0;
      }
    }
    .animate-pop {
      animation: pop-in 0.95s ease-in-out forwards;
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen">

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header -->
    <header class="text-center mb-8">
      <span class="bg-indigo-100 text-indigo-800 text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">EduTech AI Grading System</span>
      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mt-3 mb-2">⚡ 구구단 특급 소방대: 맞춤형 급수제 시스템</h1>
      <p class="text-slate-600 max-w-2xl mx-auto text-sm md:text-base">
        정답률(정확성)과 망설임 시간(인출 유창성) 데이터를 융합하여, 구구단이 두뇌에 완벽히 자동화되었는지 정밀 진단하는 초등 맞춤형 급수제 모델입니다.
      </p>
    </header>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- Left Column: Pedagogical Design / System Logic (5 Cols) -->
      <div class="lg:col-span-5 space-y-6">
        <!-- 1. 급수 기준 안내 카드 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-100 custom-shadow">
          <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <span class="p-1.5 bg-amber-100 text-amber-700 rounded-lg">📊</span>
            급수 평가 핵심 알고리즘
          </h2>
          
          <div class="space-y-4 text-xs md:text-sm">
            <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
              <span class="font-bold text-slate-800 text-sm">💡 왜 '망설임 시간'인가요?</span>
              <p class="text-slate-600 mt-1 leading-relaxed">
                정답을 맞혔더라도 3초 이상 고민했다면 머릿속으로 더하기를 반복하거나(Skip-counting) 버벅거리는 상태입니다. <strong>1.5초 이내 자동 인출</strong>이 되어야 수학 연산의 기초 체력이 형성된 것으로 판정합니다.
              </p>
            </div>

            <div class="border-t border-slate-100 pt-3">
              <span class="font-bold text-indigo-700 block mb-2">⏱️ 망설임 지표 (문제당 평균 반응 속도)</span>
              <ul class="space-y-1.5 text-slate-600">
                <li class="flex justify-between items-center">
                  <span>🚀 1.5초 미만:</span>
                  <span class="font-semibold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded">직관적 자동 인출 (신선급)</span>
                </li>
                <li class="flex justify-between items-center">
                  <span>⏱️ 1.5초 ~ 3.0초:</span>
                  <span class="font-semibold text-amber-600 bg-amber-50 px-2 py-0.5 rounded">안정적 연산 (일반급)</span>
                </li>
                <li class="flex justify-between items-center">
                  <span>🐢 3.0초 초과:</span>
                  <span class="font-semibold text-rose-600 bg-rose-50 px-2 py-0.5 rounded">망설임 상태 (기초 다지기 필요)</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 2. 급수 매트릭스 테이블 -->
        <div class="bg-white p-6 rounded-2xl border border-slate-100 custom-shadow">
          <h3 class="text-base font-bold text-slate-900 mb-3 flex items-center gap-2">
            <span class="p-1.5 bg-indigo-100 text-indigo-700 rounded-lg">🏅</span>
            구구단 급수 등급 체계
          </h3>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="border-b border-slate-100 text-slate-500">
                  <th class="pb-2 font-semibold">급수 (칭호)</th>
                  <th class="pb-2 font-semibold text-center">요구 정답률</th>
                  <th class="pb-2 font-semibold text-center">요구 평균 속도</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 text-slate-600">
                <tr class="hover:bg-slate-50">
                  <td class="py-2.5 font-bold text-indigo-600">🥇 1급 (번개 마스터)</td>
                  <td class="py-2.5 text-center font-medium text-slate-800">100%</td>
                  <td class="py-2.5 text-center text-emerald-600 font-medium">1.5초 미만</td>
                </tr>
                <tr class="hover:bg-slate-50">
                  <td class="py-2.5 font-bold text-amber-600">🥈 2급 (도사의 반열)</td>
                  <td class="py-2.5 text-center font-medium text-slate-800">95% 이상</td>
                  <td class="py-2.5 text-center text-emerald-600 font-medium">2.0초 미만</td>
                </tr>
                <tr class="hover:bg-slate-50">
                  <td class="py-2.5 font-bold text-slate-700">🥉 3급 (달리기 선수)</td>
                  <td class="py-2.5 text-center font-medium text-slate-800">90% 이상</td>
                  <td class="py-2.5 text-center text-amber-600 font-medium">2.5초 미만</td>
                </tr>
                <tr class="hover:bg-slate-50">
                  <td class="py-2.5 font-bold text-slate-500">⭐ 4급 (새싹 훈련병)</td>
                  <td class="py-2.5 text-center font-medium text-slate-800">80% 이상</td>
                  <td class="py-2.5 text-center text-amber-600 font-medium">3.5초 미만</td>
                </tr>
                <tr class="hover:bg-slate-50">
                  <td class="py-2.5 font-bold text-rose-500">🌱 5급 (시작하는 여행자)</td>
                  <td class="py-2.5 text-center font-medium text-slate-800">70% 이상</td>
                  <td class="py-2.5 text-center text-rose-500 font-medium">시간 제한 없음</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-[11px] text-slate-400 mt-3">
            * 5급 미만은 '연습이 더 필요해요!' 단계로 판정되어 학습 동기를 고취시킵니다.
          </p>
        </div>
      </div>

      <!-- Right Column: Interactive Test Dashboard (7 Cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Game Stage / Tester Card -->
        <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-100 custom-shadow relative overflow-hidden">
          
          <!-- State Indicator -->
          <div id="test-banner" class="absolute top-0 left-0 right-0 h-2 bg-slate-200 transition-all duration-300"></div>

          <!-- Section 1: Intro / Select Range -->
          <div id="screen-intro" class="space-y-6 py-4">
            <div class="text-center">
              <span class="text-4xl">🎮</span>
              <h3 class="text-xl font-black text-slate-900 mt-2">구구단 급수 검정 시험</h3>
              <p class="text-slate-500 text-sm mt-1">도전하고 싶은 단수를 골라 시험을 시작하세요!</p>
            </div>

            <!-- Options -->
            <div class="space-y-4">
              <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">검정 범위 선택</label>
                <div class="grid grid-cols-2 gap-3" id="range-selector">
                  <button onclick="selectRange('all')" id="btn-range-all" class="p-3 border-2 border-indigo-600 bg-indigo-50/50 text-indigo-700 font-bold text-sm rounded-xl text-left transition-all">
                    🎯 종합 평가 (2단~9단)
                  </button>
                  <button onclick="selectRange('low')" id="btn-range-low" class="p-3 border border-slate-200 text-slate-700 font-bold text-sm rounded-xl text-left hover:border-indigo-200 transition-all">
                    🌱 초급 단수 (2단~5단)
                  </button>
                </div>
              </div>

              <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">문항 수 선택</label>
                <div class="grid grid-cols-3 gap-3">
                  <button onclick="selectQuestionsCount(10)" id="btn-q-10" class="p-2 border-2 border-indigo-600 bg-indigo-50/50 text-indigo-700 font-bold text-xs rounded-lg text-center transition-all">10문항</button>
                  <button onclick="selectQuestionsCount(15)" id="btn-q-15" class="p-2 border border-slate-200 text-slate-700 font-bold text-xs rounded-lg text-center hover:border-indigo-200 transition-all">15문항</button>
                  <button onclick="selectQuestionsCount(20)" id="btn-q-20" class="p-2 border border-slate-200 text-slate-700 font-bold text-xs rounded-lg text-center hover:border-indigo-200 transition-all">20문항</button>
                </div>
              </div>
            </div>

            <button onclick="startTestSequence()" class="w-full py-4 bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 active:scale-[0.98] transition-all flex justify-center items-center gap-2 text-base shadow-lg shadow-indigo-200">
              ⚡ 검정 시작하기 (카운트다운 시동)
            </button>
          </div>

          <!-- Section 1-B: 3, 2, 1, 시작! 카운트다운 스크린 -->
          <div id="screen-countdown" class="hidden py-12 flex flex-col items-center justify-center min-h-[300px]">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6">마음의 준비를 하세요!</span>
            <div class="h-40 flex items-center justify-center">
              <div id="countdown-text" class="text-7xl md:text-9xl font-black text-indigo-600 transition-all duration-300"></div>
            </div>
            <p class="text-slate-500 text-xs text-center mt-6">카운트다운 직후 바로 1번 문제가 출제됩니다.</p>
          </div>

          <!-- Section 2: Active Quiz Screen (With Custom Keypad) -->
          <div id="screen-quiz" class="hidden py-2 space-y-4">
            <div class="flex justify-between items-center">
              <span id="quiz-progress" class="text-xs font-extrabold text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded-full">문항 1 / 10</span>
              <div class="flex items-center gap-1">
                <span class="text-xs font-bold text-slate-400">실시간 경과:</span>
                <span id="quiz-timer" class="text-xs font-mono font-bold text-slate-700 bg-slate-100 px-2 py-0.5 rounded">0.00초</span>
              </div>
            </div>

            <!-- The Question Area -->
            <div class="text-center py-4">
              <span class="text-xs font-bold text-slate-400 uppercase tracking-widest block mb-1">정답을 입력하세요</span>
              <div class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight" id="question-text">
                7 × 8 = ?
              </div>
              <!-- ⚡ 번개 입력 안내 문구 추가 -->
              <span class="text-[11px] font-medium text-indigo-500 bg-indigo-50 px-2 py-1 rounded-md inline-block mt-2">
                ⚡ 스마트 자동 제출: 정답 길이만큼 치면 자동으로 넘어가요!
              </span>
            </div>

            <!-- Answer Input & Screen Keypad -->
            <div class="space-y-4">
              <input type="number" id="answer-input" inputmode="none" class="w-full text-center text-3xl font-black py-2.5 border-2 border-slate-200 rounded-xl focus:border-indigo-500 focus:outline-none transition-all placeholder-slate-200" placeholder="?" readonly>
              
              <!-- 💡 어린이 맞춤형 스마트 키패드 -->
              <div class="grid grid-cols-3 gap-2 bg-slate-100 p-2.5 rounded-2xl">
                <button onclick="pressKey(1)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">1</button>
                <button onclick="pressKey(2)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">2</button>
                <button onclick="pressKey(3)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">3</button>
                
                <button onclick="pressKey(4)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">4</button>
                <button onclick="pressKey(5)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">5</button>
                <button onclick="pressKey(6)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">6</button>
                
                <button onclick="pressKey(7)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">7</button>
                <button onclick="pressKey(8)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">8</button>
                <button onclick="pressKey(9)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">9</button>
                
                <button onclick="pressBackspace()" class="key-btn py-3 bg-rose-50 text-rose-600 font-extrabold text-lg rounded-xl shadow-sm hover:bg-rose-100 transition-all flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M3 12l6.414 6.414A2 2 0 0010.828 19H20a2 2 0 002-2V7a2 2 0 00-2-2h-9.172a2 2 0 00-1.414.586L3 12z" />
                  </svg>
                </button>
                <button onclick="pressKey(0)" class="key-btn py-3 bg-white text-slate-800 font-extrabold text-xl rounded-xl shadow-sm hover:bg-slate-50 transition-all">0</button>
                <!-- 자릿수가 덜 채워졌을 때 직접 제출할 수 있는 수동 버튼으로 활용 -->
                <button onclick="submitAnswer()" class="key-btn py-3 bg-emerald-500 text-white font-extrabold text-base rounded-xl shadow-sm hover:bg-emerald-600 transition-all">확인</button>
              </div>

              <div class="text-center">
                <button onclick="cancelTest()" class="text-xs font-semibold text-slate-400 hover:text-slate-600 py-1 transition-all">
                  ❌ 이번 시험 중단하기
                </button>
              </div>
            </div>
          </div>

          <!-- Section 3: Detailed Report Card / Result Screen (With Save Feature) -->
          <div id="screen-result" class="hidden py-4 space-y-6">
            
            <!-- 📸 저장될 성적표 영역 (캡처 대상) -->
            <div id="report-card-capture" class="bg-white p-6 rounded-2xl border border-slate-200">
              <div class="text-center mb-4">
                <span class="text-5xl" id="result-badge">🎖️</span>
                <h3 class="text-2xl font-black text-slate-900 mt-2">구구단 급수증</h3>
                <p class="text-slate-400 text-[11px]">특급 구구단 평가 본부 발행</p>
              </div>

              <!-- Visual Grade Badge -->
              <div class="p-6 bg-gradient-to-br from-indigo-50 to-slate-50 rounded-2xl border border-indigo-100 text-center relative overflow-hidden mb-4">
                <div class="absolute -right-8 -bottom-8 opacity-10 text-9xl font-black select-none">PASS</div>
                <span class="text-xs font-extrabold text-indigo-700 uppercase tracking-widest block mb-1">최종 등급 판정</span>
                <div class="text-3xl font-black text-indigo-900" id="result-grade-name">🥇 1급 (번개 마스터)</div>
                <p class="text-xs text-slate-500 mt-2 leading-relaxed" id="result-grade-desc">
                  단 한 번의 망설임도 없이 즉각 대답했습니다. 우수한 연산 인출 자동화 상태입니다.
                </p>
              </div>

              <!-- Two Key Metrics Grid -->
              <div class="grid grid-cols-2 gap-4 mb-4">
                <!-- Metric 1: Accuracy -->
                <div class="p-4 border border-slate-100 bg-slate-50 rounded-xl text-center">
                  <span class="text-slate-400 text-[11px] font-bold block mb-1">정답률 (Accuracy)</span>
                  <span class="text-xl font-black text-slate-800" id="result-accuracy">100%</span>
                  <span class="text-[10px] text-slate-500 block mt-1" id="result-accuracy-detail">(10 / 10 정답)</span>
                </div>
                
                <!-- Metric 2: Hesitation -->
                <div class="p-4 border border-slate-100 bg-slate-50 rounded-xl text-center">
                  <span class="text-slate-400 text-[11px] font-bold block mb-1">평균 반응 속도</span>
                  <span class="text-xl font-black text-emerald-600" id="result-avg-time">1.25초</span>
                  <span class="text-[10px] text-slate-500 block mt-1" id="result-avg-time-detail">(망설임 없음)</span>
                </div>
              </div>

              <!-- Problem Log Area -->
              <div class="mb-4">
                <span class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">문제별 분석 기록</span>
                <div class="space-y-1.5 max-h-32 overflow-y-auto pr-1 text-[11px]" id="result-log-list">
                  <!-- Log item dynamically rendered here -->
                </div>
              </div>

              <!-- Global Rank Sharing Area inside Report Card -->
              <div class="border-t border-slate-100 pt-4 mt-4">
                <span class="block text-xs font-bold text-indigo-600 mb-2">🏆 실시간 명예의 전당 등록</span>
                <div class="flex gap-2">
                  <input type="text" id="leaderboard-name" class="flex-1 px-3 py-2 border rounded-xl text-xs font-bold focus:outline-none focus:border-indigo-500" placeholder="등록할 닉네임 (최대 6자)" maxlength="6">
                  <button onclick="submitToLeaderboard()" id="btn-submit-leaderboard" class="px-4 py-2 bg-indigo-600 text-white font-bold text-xs rounded-xl hover:bg-indigo-700 active:scale-95 transition-all">등록하기</button>
                </div>
                <div id="leaderboard-msg" class="text-[10px] mt-1.5 text-slate-400">닉네임을 입력해 전세계 친구들에게 점수를 공유해 보세요!</div>
              </div>
            </div>

            <!-- Real-time Ranking Board -->
            <div class="bg-indigo-900 text-white p-5 rounded-2xl shadow-md">
              <h4 class="text-sm font-bold flex items-center gap-2 mb-3">
                <span class="text-amber-400 text-base">👑</span>
                실시간 통합 랭킹 탑 10
              </h4>
              <div class="space-y-1 text-xs" id="leaderboard-rows">
                <div class="text-center py-4 text-indigo-200">현재 데이터 목록을 동기화하고 있습니다...</div>
              </div>
            </div>

            <!-- Action Buttons (캡처에는 포함 안 됨) -->
            <div class="space-y-2">
              <button onclick="saveAsImage()" class="w-full py-4 bg-emerald-500 text-white font-bold rounded-xl hover:bg-emerald-600 active:scale-[0.98] transition-all flex justify-center items-center gap-2 shadow-lg shadow-emerald-100">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M4 5a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V7a2 2 0 00-2-2h-1.586a1 1 0 01-.707-.293l-1.12-1.12A2 2 0 0011.172 3H8.828a2 2 0 00-1.414.586L6.293 4.707A1 1 0 015.586 5H4zm6 9a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                </svg>
                📸 결과를 사진으로 저장하기
              </button>

              <button onclick="resetTest()" class="w-full py-3 bg-slate-900 text-white font-bold rounded-xl hover:bg-slate-800 active:scale-[0.98] transition-all text-sm">
                🔄 다시 테스트하기
              </button>
            </div>
          </div>

        </div>

      </div>

    </div>

    <!-- Bottom: Developer/Educator Guide -->
    <footer class="mt-12 border-t border-slate-200 pt-8 text-slate-500 text-xs leading-relaxed max-w-4xl mx-auto space-y-4">
      <div>
        <h4 class="font-bold text-slate-700 text-sm mb-1">💡 어린이 중심의 키패드 피드백 및 이미지 저장 안내:</h4>
        <p>
          본 업데이트 버전에서는 어린이들의 모바일 태블릿 학습 편의성을 극대화하기 위해 전용 터치 키패드를 탑재하였습니다. 가상 키보드 팝업으로 인한 문제 가림 현상을 원천 방지하여 몰입감 있는 환경을 제공합니다.
          또한 <code>html2canvas</code> 기법을 사용하여 CSS 스타일링이 온전히 담긴 성적표 카드만 선별하여 기기에 다이렉트 다운로드할 수 있도록 설계하였습니다.
        </p>
      </div>
    </footer>
  </div>

  <!-- JavaScript Engine -->
  <script>
    // State management
    let testRange = 'all'; // 'all' (2-9), 'low' (2-5)
    let totalQuestions = 10;
    let currentQuestionIndex = 0;
    let questions = [];
    let userAnswers = [];
    let finalAccuracy = 0;
    let finalAvgTime = 0;
    let finalGradeName = "";
    let finalGradeBadge = "";
    let isSubmitting = false; // 중복 제출 방지 플래그
    
    // Timer variables
    let questionStartTime = 0;
    let liveTimerInterval = null;

    // --- 🏆 Firebase & Leaderboard Setup (Follow Rule 1, 2, 3) ---
    const appId = typeof __app_id !== 'undefined' ? __app_id : 'gugudan-grading-sys';
    let db = null;
    let auth = null;
    let currentUser = null;

    // Local Mock Leaderboard for immediate offline use
    let localLeaderboard = [
      { nickname: "구구대장", accuracy: 100, avgTime: 1.12, gradeName: "1급 (번개 마스터)", gradeBadge: "🏆" },
      { nickname: "빛의속도", accuracy: 100, avgTime: 1.35, gradeName: "1급 (번개 마스터)", gradeBadge: "🏆" },
      { nickname: "구구박사", accuracy: 100, avgTime: 1.48, gradeName: "1급 (번개 마스터)", gradeBadge: "🏆" },
      { nickname: "도전소년", accuracy: 95, avgTime: 1.78, gradeName: "2급 (도사의 반열)", gradeBadge: "⭐" },
      { nickname: "연습요정", accuracy: 90, avgTime: 2.12, gradeName: "3급 (달리기 선수)", gradeBadge: "🏃" }
    ];

    // Initialize Firebase Compat safely
    if (typeof __firebase_config !== 'undefined') {
      try {
        const firebaseConfig = JSON.parse(__firebase_config);
        const app = firebase.initializeApp(firebaseConfig);
        auth = firebase.auth();
        db = firebase.firestore();

        const initAuth = async () => {
          if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
            await auth.signInWithCustomToken(__initial_auth_token);
          } else {
            await auth.signInAnonymously();
          }
        };

        initAuth().catch(err => console.error("Anonymous authentication failed:", err));

        auth.onAuthStateChanged(user => {
          currentUser = user;
          loadLeaderboard();
        });
      } catch (e) {
        console.warn("Firebase config parsed but initialization failed. Falling back to local Storage.", e);
        loadLocalLeaderboard();
      }
    } else {
      loadLocalLeaderboard();
    }

    // Load Local Storage leaderboard backup if Firestore is not active
    function loadLocalLeaderboard() {
      const stored = localStorage.getItem('gugudan_local_leaderboard');
      if (stored) {
        localLeaderboard = JSON.parse(stored);
      }
      renderLeaderboardUI(localLeaderboard);
    }

    // Save to Local Leaderboard fallback
    function saveToLocalLeaderboard(newRecord) {
      localLeaderboard.push(newRecord);
      // Sort: high accuracy first, then low avgTime
      localLeaderboard.sort((a, b) => {
        if (b.accuracy !== a.accuracy) return b.accuracy - a.accuracy;
        return a.avgTime - b.avgTime;
      });
      localLeaderboard = localLeaderboard.slice(0, 10); // Top 10
      localStorage.setItem('gugudan_local_leaderboard', JSON.stringify(localLeaderboard));
      renderLeaderboardUI(localLeaderboard);
    }

    // Fetch from Firestore (No complex query, sorted in JS memory - RULE 2)
    function loadLeaderboard() {
      if (!db || !currentUser) {
        loadLocalLeaderboard();
        return;
      }

      // Rule 1: STRICT PATH
      const leaderboardColRef = db.collection('artifacts').doc(appId).collection('public').doc('data').collection('leaderboard');
      
      leaderboardColRef.get().then(snapshot => {
        const list = [];
        snapshot.forEach(doc => {
          list.push(doc.data());
        });

        // If firebase has no data yet, merge with default local records to keep look populated
        if (list.length === 0) {
          renderLeaderboardUI(localLeaderboard);
          return;
        }

        // Sort in Javascript memory to comply with Rule 2 (No Complex queries)
        list.sort((a, b) => {
          if (b.accuracy !== a.accuracy) return b.accuracy - a.accuracy;
          return a.avgTime - b.avgTime;
        });

        renderLeaderboardUI(list.slice(0, 10));
      }).catch(err => {
        console.error("Firestore leaderboard retrieval error, using local fallback:", err);
        loadLocalLeaderboard();
      });
    }

    // Render Ranking Board UI
    function renderLeaderboardUI(list) {
      const container = document.getElementById('leaderboard-rows');
      container.innerHTML = '';

      if (list.length === 0) {
        container.innerHTML = `<div class="text-center py-4 text-indigo-200">등록된 랭킹 기록이 없습니다.</div>`;
        return;
      }

      list.forEach((item, idx) => {
        let medal = `${idx + 1}등`;
        if (idx === 0) medal = "🥇";
        else if (idx === 1) medal = "🥈";
        else if (idx === 2) medal = "🥉";

        const div = document.createElement('div');
        div.className = "flex justify-between items-center bg-indigo-950/40 p-2 rounded-lg border border-indigo-800/50 mb-1";
        div.innerHTML = `
          <div class="flex items-center gap-2">
            <span class="font-extrabold w-8 text-center text-amber-400">${medal}</span>
            <span class="font-bold text-white">${item.nickname}</span>
            <span class="text-[10px] text-indigo-300 bg-indigo-800/80 px-1.5 py-0.5 rounded">${item.gradeBadge} ${item.gradeName.split(' ')[0]}</span>
          </div>
          <div class="text-right">
            <span class="font-bold text-amber-300 text-xs">${item.accuracy}%</span>
            <span class="text-[10px] text-indigo-200 ml-2">${item.avgTime.toFixed(2)}초</span>
          </div>
        `;
        container.appendChild(div);
      });
    }

    // Submit user's record to database (Global Sharing)
    function submitToLeaderboard() {
      const nicknameInput = document.getElementById('leaderboard-name');
      const nickname = nicknameInput.value.trim();
      const msgEl = document.getElementById('leaderboard-msg');
      const btnEl = document.getElementById('btn-submit-leaderboard');

      if (!nickname) {
        msgEl.innerText = "❌ 닉네임을 입력해 주세요!";
        msgEl.className = "text-[10px] mt-1.5 text-rose-400 font-bold";
        return;
      }

      // Prepare record object
      const newRecord = {
        nickname: nickname,
        accuracy: Math.round(finalAccuracy),
        avgTime: parseFloat(finalAvgTime.toFixed(2)),
        gradeName: finalGradeName,
        gradeBadge: finalGradeBadge,
        createdAt: Date.now()
      };

      btnEl.disabled = true;
      btnEl.innerText = "등록 중...";

      // Local save first
      saveToLocalLeaderboard(newRecord);

      // Rule 3: Auth Guard Before Querying
      if (db && auth.currentUser) {
        // Rule 1: STRICT PATH
        const docId = auth.currentUser.uid + "_" + Date.now();
        db.collection('artifacts').doc(appId).collection('public').doc('data').collection('leaderboard').doc(docId).set(newRecord)
          .then(() => {
            msgEl.innerText = "🎉 실시간 랭킹에 성공적으로 등록되었습니다!";
            msgEl.className = "text-[10px] mt-1.5 text-emerald-400 font-bold";
            nicknameInput.disabled = true;
            btnEl.classList.add('hidden');
            loadLeaderboard();
          })
          .catch(err => {
            console.error("Firestore writing error:", err);
            msgEl.innerText = "⚠️ 실시간 서버 저장 실패 (로컬 랭킹보드에만 우선 저장되었습니다)";
            msgEl.className = "text-[10px] mt-1.5 text-amber-400 font-bold";
            btnEl.disabled = false;
            btnEl.innerText = "다시 시도";
          });
      } else {
        msgEl.innerText = "🎉 로컬 랭킹보드에 기록이 등록되었습니다!";
        msgEl.className = "text-[10px] mt-1.5 text-emerald-400 font-bold";
        nicknameInput.disabled = true;
        btnEl.classList.add('hidden');
      }
    }

    // Range Selector Logic
    function selectRange(range) {
      testRange = range;
      const btnAll = document.getElementById('btn-range-all');
      const btnLow = document.getElementById('btn-range-low');
      if (range === 'all') {
        btnAll.className = "p-3 border-2 border-indigo-600 bg-indigo-50/50 text-indigo-700 font-bold text-sm rounded-xl text-left transition-all";
        btnLow.className = "p-3 border border-slate-200 text-slate-700 font-bold text-sm rounded-xl text-left hover:border-indigo-200 transition-all";
      } else {
        btnLow.className = "p-3 border-2 border-indigo-600 bg-indigo-50/50 text-indigo-700 font-bold text-sm rounded-xl text-left transition-all";
        btnAll.className = "p-3 border border-slate-200 text-slate-700 font-bold text-sm rounded-xl text-left hover:border-indigo-200 transition-all";
      }
    }

    // Question Count Selector Logic
    function selectQuestionsCount(count) {
      totalQuestions = count;
      [10, 15, 20].forEach(num => {
        const btn = document.getElementById(`btn-q-${num}`);
        if (num === count) {
          btn.className = "p-2 border-2 border-indigo-600 bg-indigo-50/50 text-indigo-700 font-bold text-xs rounded-lg text-center transition-all";
        } else {
          btn.className = "p-2 border border-slate-200 text-slate-700 font-bold text-xs rounded-lg text-center hover:border-indigo-200 transition-all";
        }
      });
    }

    // Generate Questions based on Selected range
    function generateQuestions() {
      questions = [];
      const usedPairs = new Set();
      
      let minDan = (testRange === 'low') ? 2 : 2;
      let maxDan = (testRange === 'low') ? 5 : 9;

      while (questions.length < totalQuestions) {
        let a = Math.floor(Math.random() * (maxDan - minDan + 1)) + minDan;
        let b = Math.floor(Math.random() * 8) + 2; // 2 to 9
        let pairKey = `${a}x${b}`;

        if (!usedPairs.has(pairKey)) {
          usedPairs.add(pairKey);
          questions.push({ a, b, answer: a * b });
        }
      }
    }

    // --- ⏰ 3, 2, 1, 시작! 카운트다운 구현 ---
    function startTestSequence() {
      // 1. 문제 미리 생성 및 초기화
      generateQuestions();
      currentQuestionIndex = 0;
      userAnswers = [];
      isSubmitting = false;

      // 2. 오프닝 숨기고 카운트다운 스크린 출력
      document.getElementById('screen-intro').classList.add('hidden');
      const countdownScreen = document.getElementById('screen-countdown');
      countdownScreen.classList.remove('hidden');

      const countTextEl = document.getElementById('countdown-text');
      const steps = ['3', '2', '1', '시작!'];
      let stepIndex = 0;

      function runCountdownStep() {
        if (stepIndex < steps.length) {
          const content = steps[stepIndex];
          countTextEl.innerText = content;
          
          // 애니메이션 리플로우 트리거
          countTextEl.classList.remove('animate-pop');
          void countTextEl.offsetWidth; 
          countTextEl.classList.add('animate-pop');

          // 단어 종류에 따라 컬러 차별화 (시작은 밝고 강렬하게!)
          if (content === '시작!') {
            countTextEl.className = "text-6xl md:text-8xl font-black text-emerald-500 tracking-wider animate-pop";
          } else {
            countTextEl.className = "text-7xl md:text-9xl font-black text-indigo-600 animate-pop";
          }

          stepIndex++;
          setTimeout(runCountdownStep, 1000);
        } else {
          // 카운트다운 종료 -> 본 시험 화면으로 진입
          countdownScreen.classList.add('hidden');
          document.getElementById('screen-quiz').classList.remove('hidden');
          loadQuestion();
        }
      }

      runCountdownStep();
    }

    // Load Single Question
    function loadQuestion() {
      const q = questions[currentQuestionIndex];
      document.getElementById('question-text').innerText = `${q.a} × ${q.b} = ?`;
      document.getElementById('quiz-progress').innerText = `문항 ${currentQuestionIndex + 1} / ${totalQuestions}`;
      
      const inputEl = document.getElementById('answer-input');
      inputEl.value = '';
      isSubmitting = false; // 새 질문에서 입력 제한 해제

      // Start Time
      questionStartTime = performance.now();
      
      // Update Live Timer UI
      clearInterval(liveTimerInterval);
      liveTimerInterval = setInterval(() => {
        let elapsed = (performance.now() - questionStartTime) / 1000;
        document.getElementById('quiz-timer').innerText = `${elapsed.toFixed(2)}초`;
        
        // Dynamic banner bar coloring based on time (Green -> Yellow -> Red)
        const banner = document.getElementById('test-banner');
        if (elapsed < 1.5) {
          banner.className = "absolute top-0 left-0 right-0 h-2 bg-emerald-400 transition-all duration-300";
        } else if (elapsed >= 1.5 && elapsed < 3.0) {
          banner.className = "absolute top-0 left-0 right-0 h-2 bg-amber-400 transition-all duration-300";
        } else {
          banner.className = "absolute top-0 left-0 right-0 h-2 bg-rose-400 transition-all duration-300";
        }
      }, 50);
    }

    // --- 💡 SCREEN KEYPAD LOGIC (With Smart Auto-Submit) ---
    function pressKey(number) {
      if (isSubmitting) return; // 전송 중일 때는 추가 입력 방지

      const inputEl = document.getElementById('answer-input');
      const q = questions[currentQuestionIndex];
      
      // 현재 출제된 문제의 '진짜 정답' 자릿수를 알아냅니다.
      const targetLength = q.answer.toString().length;

      // 정답의 원래 자릿수까지만 입력을 허용합니다.
      if (inputEl.value.length < targetLength) {
        inputEl.value += number;
      }

      // ⚡ [핵심 개선!] 자릿수가 채워지면 '즉시 타임스탬프를 정지'하고 정답을 제출합니다.
      if (inputEl.value.length === targetLength) {
        isSubmitting = true;
        const endTime = performance.now();
        // 마지막 키 터치 순간의 시간을 오차 없이 확보합니다 (시각 연출 시간 배제)
        const exactTimeTaken = (endTime - questionStartTime) / 1000; 
        
        clearInterval(liveTimerInterval); // 즉시 스크린 타이머 일시중지

        // 0.12초(120ms) 동안 화면에 아이가 입력한 정답이 잠시 머물렀다가 자연스럽게 넘어가도록 합니다.
        setTimeout(() => {
          processAnswer(inputEl.value, exactTimeTaken);
        }, 120);
      }
    }

    function pressBackspace() {
      if (isSubmitting) return;
      const inputEl = document.getElementById('answer-input');
      inputEl.value = inputEl.value.slice(0, -1);
    }

    // 물리적 키보드 대응 (PC에서 테스트용)
    document.addEventListener('keydown', function(e) {
      const quizScreen = document.getElementById('screen-quiz');
      if (quizScreen.classList.contains('hidden') || isSubmitting) return;

      if (e.key >= '0' && e.key <= '9') {
        pressKey(e.key);
      } else if (e.key === 'Backspace') {
        pressBackspace();
      } else if (e.key === 'Enter') {
        submitAnswer(); // 엔터를 눌러 수동 제출도 지원
      }
    });

    // 수동 확인 버튼 제출용 (자릿수를 다 안 채우고 틀린 답을 제출할 때 등 대비)
    function submitAnswer() {
      if (isSubmitting) return;
      const inputVal = document.getElementById('answer-input').value.trim();
      if (inputVal === '') return; 

      const endTime = performance.now();
      const exactTimeTaken = (endTime - questionStartTime) / 1000;

      isSubmitting = true;
      clearInterval(liveTimerInterval);
      processAnswer(inputVal, exactTimeTaken);
    }

    // 입력 처리 엔진
    function processAnswer(inputVal, timeTaken) {
      const q = questions[currentQuestionIndex];
      const userAnswerParsed = parseInt(inputVal);
      const isCorrect = userAnswerParsed === q.answer;

      // 기록 저장
      userAnswers.push({
        num: currentQuestionIndex + 1,
        question: `${q.a} × ${q.b}`,
        correctAnswer: q.answer,
        userAnswer: userAnswerParsed,
        isCorrect: isCorrect,
        timeTaken: timeTaken
      });

      currentQuestionIndex++;

      if (currentQuestionIndex < totalQuestions) {
        loadQuestion();
      } else {
        finishTest();
      }
    }

    // Finish Test & Process results
    function finishTest() {
      clearInterval(liveTimerInterval);
      document.getElementById('screen-quiz').classList.add('hidden');
      document.getElementById('screen-result').classList.remove('hidden');
      document.getElementById('test-banner').className = "absolute top-0 left-0 right-0 h-2 bg-indigo-600";

      // Reset leaderboard interaction fields
      document.getElementById('leaderboard-name').disabled = false;
      document.getElementById('leaderboard-name').value = '';
      document.getElementById('btn-submit-leaderboard').classList.remove('hidden');
      document.getElementById('btn-submit-leaderboard').disabled = false;
      document.getElementById('leaderboard-msg').innerText = "닉네임을 입력해 전세계 친구들에게 점수를 공유해 보세요!";
      document.getElementById('leaderboard-msg').className = "text-[10px] mt-1.5 text-slate-400";

      // Calculations
      const totalCount = userAnswers.length;
      const correctCount = userAnswers.filter(a => a.isCorrect).length;
      
      // Global 상태 갱신
      finalAccuracy = (correctCount / totalCount) * 100;
      finalAvgTime = userAnswers.reduce((sum, item) => sum + item.timeTaken, 0) / totalCount;

      // Render General Summary Score UI
      document.getElementById('result-accuracy').innerText = `${finalAccuracy.toFixed(0)}%`;
      document.getElementById('result-accuracy-detail').innerText = `(${correctCount} / ${totalCount} 정답)`;
      
      document.getElementById('result-avg-time').innerText = `${finalAvgTime.toFixed(2)}초`;
      
      let speedDetailText = "";
      if (finalAvgTime < 1.5) {
        document.getElementById('result-avg-time').className = "text-xl font-black text-emerald-600";
        speedDetailText = "🚀 직관적 자동 인출 최고 속도!";
      } else if (finalAvgTime < 2.5) {
        document.getElementById('result-avg-time').className = "text-xl font-black text-amber-600";
        speedDetailText = "⏱️ 약간의 계산 지연 (보통)";
      } else {
        document.getElementById('result-avg-time').className = "text-xl font-black text-rose-600";
        speedDetailText = "🐢 두뇌 연산 단계 (망설임 높음)";
      }
      document.getElementById('result-avg-time-detail').innerText = speedDetailText;

      // GRADE DECISION ENGINE
      if (finalAccuracy === 100 && finalAvgTime < 1.5) {
        finalGradeBadge = "🏆";
        finalGradeName = "🥇 1급 (번개 마스터)";
      } else if (finalAccuracy >= 95 && finalAvgTime < 2.0) {
        finalGradeBadge = "⭐";
        finalGradeName = "🥈 2급 (도사의 반열)";
      } else if (finalAccuracy >= 90 && finalAvgTime < 2.5) {
        finalGradeBadge = "🏃";
        finalGradeName = "🥉 3급 (달리기 선수)";
      } else if (finalAccuracy >= 80 && finalAvgTime < 3.5) {
        finalGradeBadge = "🌲";
        finalGradeName = "⭐ 4급 (새싹 훈련병)";
      } else if (finalAccuracy >= 70) {
        finalGradeBadge = "🎒";
        finalGradeName = "🌱 5급 (시작하는 여행자)";
      } else {
        finalGradeBadge = "🧩";
        finalGradeName = "연습생 (수습 소방대)";
      }

      let gradeDesc = "";
      if (finalGradeName.includes("1급")) {
        gradeDesc = "모든 정답을 1.5초 이내에 즉각 맞췄습니다. 구구단 인출이 완전히 자동화된 경지입니다!";
      } else if (finalGradeName.includes("2급")) {
        gradeDesc = "매우 빠른 반사신경과 완벽에 가까운 암기력을 자랑합니다. 조금만 더 단축하면 1급이 됩니다!";
      } else if (finalGradeName.includes("3급")) {
        gradeDesc = "계산 정확도는 훌륭하지만, 일부 구구단 단수에서 머뭇거리는 지연 현상이 존재합니다.";
      } else if (finalGradeName.includes("4급")) {
        gradeDesc = "머릿속으로 계산 과정을 거치며 맞추는 상태입니다. 반복 훈련으로 꺼내는 속도를 더 빠르게 만들어봅시다!";
      } else if (finalGradeName.includes("5급")) {
        gradeDesc = "차근차근 더해나가며 맞추는 기초 단계입니다. 포기하지 않고 연습카드를 매일 해보세요!";
      } else {
        gradeDesc = "구구단의 원리와 암기를 함께 잡아야 하는 연습 시기입니다. 짝꿍과 소리 내어 외쳐보세요!";
      }

      document.getElementById('result-badge').innerText = finalGradeBadge;
      document.getElementById('result-grade-name').innerText = finalGradeName;
      document.getElementById('result-grade-desc').innerText = gradeDesc;

      // Render problem lists
      const listContainer = document.getElementById('result-log-list');
      listContainer.innerHTML = '';

      userAnswers.forEach(item => {
        const div = document.createElement('div');
        div.className = `p-2 rounded-lg flex justify-between items-center ${item.isCorrect ? 'bg-slate-50 border border-slate-100' : 'bg-rose-50 border border-rose-100'}`;

        let speedBadge = "";
        if (item.timeTaken < 1.5) {
          speedBadge = `<span class="bg-emerald-100 text-emerald-800 text-[9px] font-bold px-1.5 py-0.5 rounded">번개 (${item.timeTaken.toFixed(2)}초)</span>`;
        } else if (item.timeTaken < 3.0) {
          speedBadge = `<span class="bg-amber-100 text-amber-800 text-[9px] font-bold px-1.5 py-0.5 rounded">고민 (${item.timeTaken.toFixed(2)}초)</span>`;
        } else {
          speedBadge = `<span class="bg-rose-100 text-rose-800 text-[9px] font-bold px-1.5 py-0.5 rounded">망설임 (${item.timeTaken.toFixed(2)}초)</span>`;
        }

        const mark = item.isCorrect ? '<span class="text-emerald-500 font-bold mr-1">○</span>' : '<span class="text-rose-500 font-bold mr-1">✗</span>';
        const userAnswerText = item.isCorrect ? '' : ` <span class="text-rose-500 font-bold text-[9px]">입력: ${item.userAnswer}</span>`;

        div.innerHTML = `
          <div class="flex items-center gap-1.5 text-[10px]">
            ${mark}
            <span class="font-bold text-slate-800">${item.question}</span>
            <span class="text-slate-500">= ${item.correctAnswer}</span>
            ${userAnswerText}
          </div>
          <div>${speedBadge}</div>
        `;
        listContainer.appendChild(div);
      });

      // 동기화된 DB 랭킹 새로 불러오기
      loadLeaderboard();
    }

    // --- 📸 HTML5 CANVAS IMAGE GENERATION LOGIC ---
    function saveAsImage() {
      const captureArea = document.getElementById('report-card-capture');
      const saveBtn = event.currentTarget;
      const originalText = saveBtn.innerHTML;
      
      saveBtn.innerHTML = `
        <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        성적표를 사진으로 굽는 중...
      `;
      saveBtn.disabled = true;

      // html2canvas로 카드 이미지 캡처 실행
      html2canvas(captureArea, {
        backgroundColor: '#ffffff',
        scale: 2, // 높은 해상도
        useCORS: true
      }).then(canvas => {
        const link = document.createElement('a');
        const today = new Date().toISOString().slice(0, 10);
        link.download = `구구단_급수증_${today}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
        
        saveBtn.innerHTML = originalText;
        saveBtn.disabled = false;
      }).catch(err => {
        console.error("이미지 저장 실패:", err);
        saveBtn.innerHTML = `❌ 저장 실패 (다시 시도)`;
        saveBtn.disabled = false;
        setTimeout(() => {
          saveBtn.innerHTML = originalText;
        }, 3000);
      });
    }

    // Cancel Test Half-way
    function cancelTest() {
      clearInterval(liveTimerInterval);
      resetTest();
    }

    // Reset Test to Intro
    function resetTest() {
      currentQuestionIndex = 0;
      userAnswers = [];
      isSubmitting = false;
      document.getElementById('screen-result').classList.add('hidden');
      document.getElementById('screen-quiz').classList.add('hidden');
      document.getElementById('screen-countdown').classList.add('hidden');
      document.getElementById('screen-intro').classList.remove('hidden');
      document.getElementById('test-banner').className = "absolute top-0 left-0 right-0 h-2 bg-slate-200";
    }
  </script>

</body>
